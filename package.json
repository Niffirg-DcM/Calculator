{
  "name": "calc",
  "version": "1.0.0",
  "description": "A C++ scientific calculator with Supabase telemetry",
  "scripts": {
    "configure": "cmake -S . -B build",
    "build": "npm run configure && cmake --build build",
    "start": "npm run build && npx env-cmd ./build/app",
    "clean": "rm -rf build bin"
  },
  "devDependencies": {
    "env-cmd": "^10.1.0"
  }
}